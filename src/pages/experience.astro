import BaseLayout from "@layouts/BaseLayout.astro"; import PageHero from "@components/PageHero.astro";
const roles=[{title:"Software Engineer",company:"Yelp",period:"Sep 2022 – Present",focus:"Platform security, access management, internal systems, least-privilege enforcement.",highlights:["Leading centralized access management platform design and delivery.","Built governance systems for non-SSO applications.","Owned least-privilege enforcement across large-scale access grants.","Contributed to planning, technical design, reliability, and mentoring."]},{title:"Software Developer",company:"MindSea",period:"Mar 2020 – Aug 2022",focus:"Full-stack product delivery, enterprise application development, client-facing technical leadership.",highlights:["Built web, service, and native/hybrid mobile applications.","Integrated Auth0 for enterprise authentication and authorization.","Led delivery, estimates, consultations, and technical ownership.","Improved development process through CI/CD and PR review standards."]},{title:"Research Assistant",company:"NICHE Research Group, Dalhousie University",period:"Sep 2017 – Feb 2020",focus:"Healthcare research prototypes, ML/AI, speech recognition, NLP, and teaching support.",highlights:["Built full-stack prototype for healthcare risk management research.","Applied ML/AI algorithms using CUDA-accelerated servers.","Introduced Jenkins CI/CD and interactive visualizations.","Supported research, labs, lectures, and student progress."]},{title:"Software Engineer",company:"Techlogix",period:"Oct 2015 – Sep 2017",focus:"Enterprise finance and healthcare systems.",highlights:["Owned core financial systems for a global exchange and remittance company.","Built healthcare video conferencing module with HIPAA compliance requirements.","Mentored new engineers and improved delivery practices.","Introduced Agile practices into legacy long-running projects."]},{title:"Web Developer",company:"Four-Nodes",period:"Jul 2013 – Oct 2015",focus:"Web applications, interactive visualizations, and automation.",highlights:["Developed and enhanced web-based projects requiring interactive visualizations.","Created automated bots for bulk buying and price tracking."]}];
---
<BaseLayout title="Experience — Syed M Faizan" description="Career timeline for Syed M Faizan."><PageHero eyebrow="Experience" title="A career across full-stack systems, research, enterprise software, and platform security." description="This timeline summarizes the themes and impact across my professional roles." /><section class="mx-auto max-w-5xl px-5 pb-20 lg:px-8"><div class="space-y-6">{roles.map((role)=>(<article class="rounded-3xl border border-slate-200 bg-white p-7 shadow-sm"><div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between"><div><h2 class="text-2xl font-bold tracking-tight text-ink-950">{role.title}</h2><p class="mt-1 font-semibold text-brand-700">{role.company}</p></div><p class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-ink-700">{role.period}</p></div><p class="mt-5 text-base leading-8 text-ink-600">{role.focus}</p><ul class="mt-5 grid gap-3 md:grid-cols-2">{role.highlights.map((item)=>(<li class="rounded-2xl bg-slate-50 p-4 text-sm leading-7 text-ink-700">{item}</li>))}</ul></article>))}</div></section></BaseLayout>
