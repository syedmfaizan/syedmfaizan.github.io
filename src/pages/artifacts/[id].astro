---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
export async function getStaticPaths() {
  const entries = await getCollection("artifacts");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}
const { entry } = Astro.props;
---

<BaseLayout
  title={`${entry.data.title} — Syed M Faizan`}
  description={entry.data.description}
>
  <article class="mx-auto max-w-4xl px-5 py-16 lg:px-8">
    <a
      href="/artifacts"
      class="mb-8 inline-block text-sm font-semibold text-brand-700 hover:text-brand-600"
      >← Artifacts</a
    >
    <div class="prose-custom">
      <p class="section-label mb-4">
        {entry.data.type} · {entry.data.tags?.join(" · ")}
      </p><h1>{entry.data.title}</h1><p class="text-xl leading-9 text-ink-600">
        {entry.data.description}
      </p>{entry.rendered}
    </div>
  </article>
</BaseLayout>
