---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import Card from "@components/Card.astro";
import { getCollection } from "astro:content";
const items = (await getCollection("writing")).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="Writing — Syed M Faizan" description="Short, practical notes about platform security, IAM, internal platforms, and system design.">
  <PageHero eyebrow="Writing" title="Engineering notes." description="Short, practical notes about platform security, IAM, internal platforms, and system design." />
  <section class="mx-auto grid max-w-7xl gap-5 px-5 pb-20 md:grid-cols-2 lg:grid-cols-3 lg:px-8">
    {items.map((item)=>(<Card href={`/writing/${item.slug}`} title={item.data.title} description={item.data.description} meta={`${item.data.readingTime} · ${item.data.tags[0] ?? "Engineering"}`} />))}
  </section>
</BaseLayout>
