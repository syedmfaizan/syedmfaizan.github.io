---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
const talks = [
  {
    title: "Least Privilege Without Breaking Production",
    description:
      "A practical look at detecting, notifying, and revoking unused access safely.",
  },
  {
    title: "Why Non-SSO Apps Become Security Blind Spots",
    description:
      "How application ownership, onboarding, and governance reduce risk.",
  },
  {
    title: "The Hidden Work of Internal Platform Engineering",
    description:
      "Why successful platforms are more about adoption than architecture.",
  },
  {
    title: "From Full-Stack Engineer to Platform Security Engineer",
    description:
      "Lessons from moving into IAM, governance, and security-focused systems.",
  },
];
---

<BaseLayout
  title="Speaking — Syed M Faizan"
  description="Speaking topics for Syed M Faizan."
  ><PageHero
    eyebrow="Speaking"
    title="Talks I could give."
    description="Topics for technical talks, meetups, panels, podcasts, and conference proposals."
  /><section class="mx-auto max-w-6xl px-5 pb-20 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2">
      {
        talks.map((talk) => (
          <article class="rounded-3xl border border-slate-200 bg-white p-7 shadow-sm">
            <>
              <h2 class="text-2xl font-bold tracking-tight text-ink-950">
                {talk.title}
              </h2>
              <p class="mt-4 leading-8 text-ink-600">{talk.description}</p>
            </>
          </article>
        ))
      }
    </div>
  </section><CTA /></BaseLayout
>
