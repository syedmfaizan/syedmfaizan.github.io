---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { Mail, Linkedin, Github, MapPin } from "lucide-astro";
import { SITE } from "../site.config";
---

<BaseLayout title="Contact — Syed M Faizan" description="Contact Syed M Faizan."
  ><PageHero
    eyebrow="Contact"
    title="Open to meaningful engineering conversations."
    description="Reach out for platform security, IAM, senior IC engineering, technical writing, speaking, or select advisory conversations."
  /><section
    class="mx-auto grid max-w-6xl gap-8 px-5 pb-20 lg:grid-cols-[0.85fr_1.15fr] lg:px-8"
  >
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <h2 class="text-2xl font-bold text-ink-950">Best-fit conversations</h2><ul
        class="mt-6 space-y-3 text-ink-600"
      >
        <li>Staff / senior IC engineering roles</li><li>
          Platform security and IAM systems
        </li><li>Developer infrastructure and internal platforms</li><li>
          Security automation and governance
        </li><li>Speaking, writing, and technical discussions</li>
      </ul>
    </div><div
      class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm"
    >
      <h2 class="text-2xl font-bold text-ink-950">Contact details</h2><div
        class="mt-6 grid gap-4"
      >
        <a
          class="flex items-center gap-3 rounded-2xl bg-slate-50 p-4 text-ink-700 hover:bg-brand-50 hover:text-brand-700"
          href={`mailto:${SITE.email}`}><Mail size={20} /> {SITE.email}</a
        ><a
          class="flex items-center gap-3 rounded-2xl bg-slate-50 p-4 text-ink-700 hover:bg-brand-50 hover:text-brand-700"
          href={SITE.linkedin}
          ><Linkedin size={20} /> linkedin.com/in/syedmfaizan</a
        ><a
          class="flex items-center gap-3 rounded-2xl bg-slate-50 p-4 text-ink-700 hover:bg-brand-50 hover:text-brand-700"
          href={SITE.github}><Github size={20} /> github.com/syedmfaizan</a
        ><div
          class="flex items-center gap-3 rounded-2xl bg-slate-50 p-4 text-ink-700"
        >
          <MapPin size={20} />
          {SITE.location}
        </div>
      </div><div
        class="mt-8 rounded-2xl bg-brand-50 p-5 text-sm leading-7 text-ink-700"
      >
        Want a contact form? Connect Formspree, Basin, or Resend and replace
        this card with a form action. Starting with email keeps the first
        version simple and reliable.
      </div>
    </div>
  </section></BaseLayout
>
