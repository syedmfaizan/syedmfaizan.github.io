---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { SITE } from "../site.config";
---

<BaseLayout
  title="Resume — Syed M Faizan"
  description="View and download the resume of Syed M Faizan."
  ><PageHero
    eyebrow="Resume"
    title="Resume"
    description="A concise overview of my experience across platform security, IAM, distributed systems, full-stack software engineering, and ML/NLP research."
  /><section class="mx-auto max-w-5xl px-5 pb-20 lg:px-8">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <div
        class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
      >
        <div>
          <h2 class="text-2xl font-bold text-ink-950">Latest resume</h2><p
            class="mt-2 text-ink-600"
          >
            Replace the bundled PDF with the latest version when needed.
          </p>
        </div><ButtonLink href={SITE.resumePath}>Download PDF</ButtonLink>
      </div><div class="mt-8 rounded-2xl bg-slate-50 p-6">
        <h3 class="text-lg font-bold text-ink-950">Profile summary</h3><p
          class="mt-3 leading-8 text-ink-600"
        >
          Software engineer building secure, resilient, and scalable systems
          with 12+ years of full-stack and backend-heavy experience. Recent work
          focuses on platform security, access management, least-privilege
          enforcement, application governance, distributed systems, and
          engineering leadership.
        </p>
      </div>
    </div>
  </section></BaseLayout
>
