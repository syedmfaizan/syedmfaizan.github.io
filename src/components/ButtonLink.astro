---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  target?: string;
}
const { href, variant = "primary", target } = Astro.props;
const classes = {
  primary: "bg-ink-950 text-white shadow-sm hover:bg-brand-700",
  secondary:
    "border border-slate-300 bg-white text-ink-900 shadow-sm hover:border-brand-500 hover:text-brand-700",
  ghost: "text-brand-700 hover:bg-brand-50",
};
---

<a
  href={href}
  target={target}
  rel={target === "_blank" ? "noreferrer" : undefined}
  class={`focus-ring inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold ${classes[variant]}`}
  ><slot /></a
>
