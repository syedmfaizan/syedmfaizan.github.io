---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}
const { eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["mb-8", align === "center" ? "text-center" : ""]}>
  {eyebrow && <p class="section-label mb-3">{eyebrow}</p>}<h2
    class="text-3xl font-bold tracking-tight text-ink-950 md:text-4xl"
  >
    {title}
  </h2>{
    description && (
      <p
        class:list={[
          "mt-4 text-base leading-8 text-ink-600",
          align === "center" ? "mx-auto max-w-2xl" : "max-w-3xl",
        ]}
      >
        {description}
      </p>
    )
  }
</div>
