---
interface Props {
  href: string;
  title: string;
  description: string;
  meta?: string;
}
const { href, title, description, meta } = Astro.props;
---

<a
  href={href}
  class="group focus-ring block rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft"
  >{
    meta && (
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-brand-600">
        {meta}
      </p>
    )
  }<h3
    class="text-xl font-bold tracking-tight text-ink-950 group-hover:text-brand-700"
  >
    {title}
  </h3><p class="mt-3 text-sm leading-7 text-ink-600">{description}</p><p
    class="mt-5 text-sm font-semibold text-brand-700"
  >
    Read more →
  </p></a
>
