---
import { ShieldCheck, Boxes, UsersRound, Activity, Brain } from "lucide-astro";
import { CORE_AREAS } from "../site.config";
const icons = [ShieldCheck, Boxes, UsersRound, Activity, Brain];
---

<section class="mx-auto max-w-7xl px-5 py-14 lg:px-8">
  <div class="mb-8">
    <p class="section-label mb-3">Expertise</p><h2
      class="text-3xl font-bold tracking-tight text-ink-950 md:text-4xl"
    >
      Core areas
    </h2>
  </div><div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
    {
      CORE_AREAS.map((area, index) => {
        const Icon = icons[index];
        return (
          <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
            <>
              <div class="mb-5 grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-700">
                <Icon size={26} />
              </div>
              <h3 class="text-lg font-bold text-ink-950">{area.title}</h3>
              <p class="mt-3 text-sm leading-7 text-ink-600">
                {area.description}
              </p>
            </>
          </article>
        );
      })
    }
  </div>
</section>
