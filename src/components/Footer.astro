---
import { Mail, Linkedin, Github, MapPin } from "lucide-astro";
import { NAV_ITEMS, SITE } from "../site.config";
const year = new Date().getFullYear();
---
<footer class="bg-ink-950 text-white">
  <section class="mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.25fr_1fr_1fr_1.25fr] lg:px-8">
    <div><div class="mb-5 flex items-center gap-3"><span class="grid h-10 w-10 place-items-center rounded-xl border border-white/30 text-sm font-bold tracking-wider">SF</span><span class="font-bold uppercase tracking-[0.18em]">Syed M Faizan</span></div><p class="max-w-sm text-sm leading-7 text-slate-300">Software engineer focused on building secure, resilient, and scalable systems with real operational impact.</p></div>
    <div><h2 class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-slate-400">Navigation</h2><ul class="space-y-2">{NAV_ITEMS.slice(0, 5).map((item) => (<li><a class="text-sm text-slate-300 hover:text-white" href={item.href}>{item.label}</a></li>))}</ul></div>
    <div><h2 class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-slate-400">Resources</h2><ul class="space-y-2">{NAV_ITEMS.slice(5).map((item) => (<li><a class="text-sm text-slate-300 hover:text-white" href={item.href}>{item.label}</a></li>))}</ul></div>
    <div><h2 class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-slate-400">Connect</h2><ul class="space-y-3 text-sm text-slate-300"><li class="flex items-center gap-3"><MapPin size={16} /> {SITE.location}</li><li class="flex items-center gap-3"><Mail size={16} /> <a href={`mailto:${SITE.email}`} class="hover:text-white">{SITE.email}</a></li><li class="flex items-center gap-3"><Linkedin size={16} /> <a href={SITE.linkedin} class="hover:text-white">linkedin.com/in/syedmfaizan</a></li><li class="flex items-center gap-3"><Github size={16} /> <a href={SITE.github} class="hover:text-white">github.com/syedmfaizan</a></li></ul></div>
  </section>
  <div class="border-t border-white/10"><div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-6 text-sm text-slate-400 md:flex-row md:items-center md:justify-between lg:px-8"><p>© {year} Syed M Faizan. All rights reserved.</p><p>Built with Astro, TypeScript, Tailwind, and MDX.</p></div></div>
</footer>
