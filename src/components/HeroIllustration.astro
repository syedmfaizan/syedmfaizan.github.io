---
import { ShieldCheck, Cloud, Database, KeyRound, Activity, Boxes } from "lucide-astro";
---
<div class="relative mx-auto aspect-[1.2/1] max-w-xl overflow-hidden rounded-[2rem] border border-slate-200 bg-gradient-to-br from-brand-50 via-white to-slate-100 p-6 shadow-soft"><div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-brand-100 blur-3xl"></div><div class="absolute -bottom-20 left-10 h-56 w-56 rounded-full bg-slate-200 blur-3xl"></div><div class="relative grid h-full place-items-center"><div class="relative w-full max-w-md rounded-3xl border border-slate-300 bg-ink-950 p-5 shadow-2xl"><div class="mb-4 flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-red-400"></span><span class="h-3 w-3 rounded-full bg-yellow-400"></span><span class="h-3 w-3 rounded-full bg-green-400"></span></div><div class="grid gap-3"><div class="h-4 w-3/4 rounded bg-slate-700"></div><div class="h-4 w-5/6 rounded bg-slate-800"></div><div class="h-4 w-2/3 rounded bg-brand-700/70"></div><div class="mt-2 grid grid-cols-3 gap-3"><div class="rounded-2xl border border-slate-700 bg-slate-900 p-3"><ShieldCheck class="text-brand-100" size={28} /></div><div class="rounded-2xl border border-slate-700 bg-slate-900 p-3"><KeyRound class="text-brand-100" size={28} /></div><div class="rounded-2xl border border-slate-700 bg-slate-900 p-3"><Activity class="text-brand-100" size={28} /></div></div></div></div><div class="absolute left-4 top-8 rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-soft"><Cloud class="text-brand-600" size={28} /></div><div class="absolute right-4 top-12 rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-soft"><Database class="text-brand-600" size={28} /></div><div class="absolute bottom-8 left-8 rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-soft"><Boxes class="text-brand-600" size={28} /></div></div></div>
