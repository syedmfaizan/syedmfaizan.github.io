---
interface Props { eyebrow?: string; title: string; description?: string; }
const { eyebrow, title, description } = Astro.props;
---
<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8"><div class="max-w-4xl">{eyebrow && <p class="section-label mb-4">{eyebrow}</p>}<h1 class="text-4xl font-bold tracking-tight text-ink-950 md:text-6xl">{title}</h1>{description && <p class="mt-6 text-lg leading-9 text-ink-600">{description}</p>}</div></section>
